# ss ile aynı Supabase Auth projesi
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Yalnız sunucu/senkron scriptleri için; NEXT_PUBLIC_ olarak tanımlamayın
SUPABASE_SERVICE_ROLE_KEY=
# Opsiyonel Gmail salt-okunur tarama (Workspace service account, base64 JSON)
GOOGLE_SA_KEY_B64=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mutabakat yanıt bağlantıları + iç bildirim e-postası
MUTABAKAT_TOKEN_SECRET=minimum-32-karakter-rastgele-deger
MUTABAKAT_BILDIRIM_TO=
MUTABAKAT_SEND_ENABLED=true
MUTABAKAT_ALLOWED_SENDER_DOMAINS=hidroteknik.com.tr

# WhatsApp hatırlatma — ss ile ORTAK Baileys ofis botu (Meta Cloud API DEĞİL).
# Gönderim: mesaj ortak `whatsapp_kuyruk` tablosuna yazılır (SUPABASE_SERVICE_ROLE_KEY ile),
# ss `tools/whatsapp-bot` (ofis PC'si) çekip WhatsApp'tan DM olarak gönderir.
# KobiTahsilat'ın bota erişmesi/Meta anahtarı GEREKMEZ; yalnız bu bayrakla enqueue açılır/kapanır.
WHATSAPP_SEND_ENABLED=true
# Not: WHATSAPP_BOT_SECRET botun poll ettiği ss uç noktasında tanımlıdır (bu projede gerekmez).

# Tahsilat otomasyonu (cron + canlı gönderim anahtarı)
OTOMATIK_TAHSILAT_ENABLED=false
CRON_SECRET=minimum-32-karakter-rastgele-deger
RESEND_API_KEY=
MAIL_FROM=Hidroteknik <muhasebe@hidroteknik.com.tr>

# Opsiyonel: Mikro ERP canlı senkron (scripts/sync-mikro-bakiyeler.mjs)
MIKRO_BASE_URL=https://YOUR-MIKRO-HOST/api/apiMethods
MIKRO_API_KEY=
MIKRO_FIRMA_KODU=26
MIKRO_CALISMA_YILI=2026
MIKRO_KULLANICI_KODU=
MIKRO_SIFRE_GUN=
